# Copy to .env.development.local (gitignored) or set when building.

# Leave empty for local dev: Vite proxies /api to FastAPI (see VITE_DEV_PROXY_TARGET).
# VITE_API_BASE=

# iPhone on same Wi‑Fi / Capacitor / production static build — your Mac or cloud API:
# VITE_API_BASE=http://192.168.1.42:8000
# VITE_API_BASE=https://api.yourdomain.com

# Where Vite dev proxy sends /api (default FastAPI on this machine)
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
