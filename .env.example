# Copy to .env at repo root (never commit .env).

# --- Required for AI explanations (server only; never in frontend) ---
OPENAI_API_KEY=sk-proj-your-key-here

# Optional: query real account usage in notebooks/openai_usage.ipynb
# Admin key with api.usage.read — NOT the same as OPENAI_API_KEY
# Create at platform.openai.com/settings/organization/admin-keys
# OPENAI_ADMIN_KEY=sk-admin-your-key-here

# --- API server ---
ENV=development
API_HOST=127.0.0.1
API_PORT=8000

# Comma-separated browser origins allowed to call the API.
# For iPhone testing add your Mac LAN IP, e.g.:
# CORS_ORIGINS=http://192.168.1.42:5173,http://192.168.1.42:8000,capacitor://localhost
CORS_ORIGINS=

# Stockfish binary (default: stockfish on PATH)
# STOCKFISH_PATH=/opt/homebrew/bin/stockfish

# --- Rate limit (in-memory per IP; use Redis in production) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
